# MOAT is a control-plane repo. It tracks tracking artifacts (status.json,
# plan.md, notes.md, stats.jsonl) but NOT the working clones of the forks or
# any scratch. The actual port lives in each project's jeffdaily fork.

projects/*/src/
projects/*/build/
projects/*/build-*/
projects/*/build_*/
projects/*/install/
projects/*/install-*/
projects/*/install_*/
projects/*/.lock
projects/*/.claim
projects/.selection.lock
agent_space/

# discover.py --code-search resumable checkpoint (per-repo meta + surfacing);
# regenerated each run, never a tracked artifact.
data/.code_search_cache.json

# Python
__pycache__/
*.pyc
*.pyo
_deps/
projects/rmcl/rmagine_src/

# clang/hip offload-bundle per-TU intermediates (never source)
*.o.0.*

# CMake build artifacts (by name, at any depth -- a validator that configures at
# the repo root or inside config/ drops these; never tracked content).
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
/Makefile
/solution-sum.json

# Build/test-run artifacts that land at the repo root when a validator runs a
# build or demo from the wrong cwd (real validation scratch belongs in
# agent_space/). MOAT tracks none of these.
/build-*/
/lfs-*/
/app/
/bin/
/lib/
/cache/
/examples/
/octproz*/
/DemoOutput_*/
*.ply
*.ohm
*.vtk
*.qmake.stash
*.log
/CPackConfig.cmake
/CPackSourceConfig.cmake
/DartConfiguration.tcl
/CTestTestfile.cmake
/cmake_install.cmake
/HConfig.h
/highs*.cmake
/highs_export.h
/highs-config*.cmake

# Per-arch / compare scratch dirs created at the projects/ level instead of
# agent_space/ (these are not adopted projects -- adopted projects have a
# status.json and an upstream repo name, never a -gfx*/-build/-revalidate suffix).
projects/*-gfx1100/
projects/*-gfx90a/
projects/*-gfx1101/
projects/*-gfx1201/
projects/*-new-build/
projects/*-old-build/
projects/*-revalidate/
projects/*-converge/
projects/*-stage2-geom/
projects/*-cmp-*/
