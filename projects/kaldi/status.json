    "windows-gfx1151": {
      "state": "port-ready",
      "blocked": true,
      "blocked_reason": "kaldi ROCm build is POSIX-only: configure_rocm() explicitly gates on uname==Linux (src/configure:308-316); exits 1 on Windows/MSYS2 with 'ROCm is only supported with 64-bit Linux builds'. The tools/ chain (OpenFST autoconf/Makefile, sox, OpenBLAS) is equally POSIX-only. The CMake build path (cmake/INSTALL.md) has no ROCm/HIP support at all. The Windows/.sln path (windows/INSTALL.md) explicitly says no CUDA/GPU support. No Windows-native ROCm build path exists; porting the autotools configure+Makefile system to Windows is out of ROCm-port scope.",
      "validated_sha": null,
