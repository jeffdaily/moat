{"kind":"phase","ts":"2026-06-06T02:23:22Z","phase":"test","seconds":1.626,"exit":0,"cmd":"/b/develop/TheRock/external-builds/pytorch/.venv/Scripts/python.exe -c \nimport torch\nimport simple_knn._C as C\npts = torch.randn(1024, 3, device='cuda')\ndist2 = C.distCUDA2(pts)\nassert dist2.shape == (1024,), f'unexpected shape: {dist2.shape}'\nassert dist2.isfinite().all(), 'non-finite distances'\nassert (dist2 >= 0).all(), 'negative distances'\nprint(f'simple_knn distCUDA2: shape={dist2.shape}, min={dist2.min():.4f}, max={dist2.max():.4f}')\nprint('simple_knn PASS')\n"}
{"kind":"phase","ts":"2026-06-06T02:23:29Z","phase":"test","seconds":1.593,"exit":0,"cmd":"/b/develop/TheRock/external-builds/pytorch/.venv/Scripts/python.exe -c \nimport torch\nfrom fused_ssim import fused_ssim\nimg = torch.rand(1, 3, 256, 256, device='cuda')\ngt = torch.rand(1, 3, 256, 256, device='cuda')\nval = fused_ssim(img, gt)\nprint(f'fused_ssim: val={val.item():.4f}, finite={val.isfinite().item()}')\nassert val.isfinite(), 'SSIM is not finite'\nassert 0 <= val.item() <= 1, f'SSIM out of range: {val.item()}'\nprint('fused_ssim PASS')\n"}
