{"kind":"phase","ts":"2026-06-07T19:29:55Z","phase":"test","seconds":2.449,"exit":0,"cmd":"bash -c \ncd /var/lib/jenkins/moat/agent_space/scamp_sumthresh\nSCAMP=/var/lib/jenkins/moat/projects/SCAMP/src/build/SCAMP\nINPUT=/var/lib/jenkins/moat/projects/SCAMP/src/test/SampleInput/randomwalk8K.txt\n\n# Test all 3 thresholds: GPU vs CPU SUM_THRESH\nfor THRESH in 0.0 0.125 0.5; do\n  HIP_VISIBLE_DEVICES=2 $SCAMP --window=100 --input_a_file_name=$INPUT --profile_type=SUM_THRESH --threshold=$THRESH --max_tile_size=2000000 2>&1 | grep -E 'Finished|Done'\n  mv mp_columns_out mp_columns_out_gpu_final_$THRESH\n  $SCAMP --window=100 --input_a_file_name=$INPUT --profile_type=SUM_THRESH --threshold=$THRESH --max_tile_size=2000000 --no_gpu --num_cpu_workers=1 2>&1 | grep -E 'Finished|Done'\n  mv mp_columns_out mp_columns_out_cpu_final_$THRESH\ndone\n\npython3 - <<'PYEOF'\nimport numpy as np, pandas as pd, sys\nall_pass = True\nfor thresh in [0.0, 0.125, 0.5]:\n    gpu = np.nan_to_num(np.array(pd.read_csv(f'mp_columns_out_gpu_final_{thresh}', sep=' ', header=None, na_values='-nan(ind)')).squeeze(), nan=0.0)\n    cpu = np.nan_to_num(np.array(pd.read_csv(f'mp_columns_out_cpu_final_{thresh}', sep=' ', header=None, na_values='-nan(ind)')).squeeze(), nan=0.0)\n    md = np.max(np.abs(gpu - cpu))\n    ok = md < 0.001\n    all_pass = all_pass and ok\n    print(f'thresh={thresh}: max_diff={md:.2e} {\"PASS\" if ok else \"FAIL\"}')\nsys.exit(0 if all_pass else 1)\nPYEOF\n"}
