diff --git a/cpp/include/raft/linalg/detail/eig.cuh b/cpp/include/raft/linalg/detail/eig.cuh
index b051481..8cb6f27 100644
--- a/cpp/include/raft/linalg/detail/eig.cuh
+++ b/cpp/include/raft/linalg/detail/eig.cuh
@@ -45,6 +45,55 @@ void eigDC_legacy(raft::resources const& handle,
 {
   cusolverDnHandle_t cusolverH = resource::get_cusolver_dn_handle(handle);
 
+#if defined(USE_HIP) || defined(__HIP_PLATFORM_AMD__)
+  // rocSOLVER's syevd is divide-and-conquer (STEDC) on the tridiagonalized
+  // matrix and fails to converge (dev_info != 0) on the clustered/near-
+  // degenerate spectra Lanczos produces. Use the Jacobi eigensolver
+  // (hipsolverDn{S,D}syevj), which is iterative and robust on clustered
+  // eigenvalues, on the same dense symmetric T. Stays fully on device.
+  syevjInfo_t syevj_params = nullptr;
+  RAFT_CUSOLVER_TRY(cusolverDnCreateSyevjInfo(&syevj_params));
+  RAFT_CUSOLVER_TRY(cusolverDnXsyevjSetTolerance(syevj_params, math_t(1.e-7)));
+  RAFT_CUSOLVER_TRY(cusolverDnXsyevjSetMaxSweeps(syevj_params, 100));
+
+  int lwork;
+  RAFT_CUSOLVER_TRY(cusolverDnsyevj_bufferSize(cusolverH,
+                                               CUSOLVER_EIG_MODE_VECTOR,
+                                               CUBLAS_FILL_MODE_UPPER,
+                                               static_cast<int>(n_rows),
+                                               eig_vectors,
+                                               static_cast<int>(n_cols),
+                                               eig_vals,
+                                               &lwork,
+                                               syevj_params));
+
+  rmm::device_uvector<math_t> d_work(lwork, stream);
+  rmm::device_scalar<int> d_dev_info(stream);
+
+  raft::matrix::copy(handle,
+                     make_device_matrix_view<const math_t>(in, n_rows, n_cols),
+                     make_device_matrix_view<math_t>(eig_vectors, n_rows, n_cols));
+
+  RAFT_CUSOLVER_TRY(cusolverDnsyevj(cusolverH,
+                                    CUSOLVER_EIG_MODE_VECTOR,
+                                    CUBLAS_FILL_MODE_UPPER,
+                                    static_cast<int>(n_rows),
+                                    eig_vectors,
+                                    static_cast<int>(n_cols),
+                                    eig_vals,
+                                    d_work.data(),
+                                    lwork,
+                                    d_dev_info.data(),
+                                    syevj_params,
+                                    stream));
+  RAFT_CUDA_TRY(cudaGetLastError());
+
+  auto dev_info = d_dev_info.value(stream);
+  RAFT_CUSOLVER_TRY(cusolverDnDestroySyevjInfo(syevj_params));
+  ASSERT(dev_info == 0,
+         "eig.cuh: eigensolver couldn't converge to a solution. "
+         "This usually occurs when some of the features do not vary enough.");
+#else
   int lwork;
   RAFT_CUSOLVER_TRY(cusolverDnsyevd_bufferSize(cusolverH,
                                                CUSOLVER_EIG_MODE_VECTOR,
@@ -79,6 +128,7 @@ void eigDC_legacy(raft::resources const& handle,
   ASSERT(dev_info == 0,
          "eig.cuh: eigensolver couldn't converge to a solution. "
          "This usually occurs when some of the features do not vary enough.");
+#endif
 }
 
