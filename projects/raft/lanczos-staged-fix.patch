diff --git a/cpp/cmake/hip/raft_hip.cmake b/cpp/cmake/hip/raft_hip.cmake
index 2fa6b04..a96b913 100644
--- a/cpp/cmake/hip/raft_hip.cmake
+++ b/cpp/cmake/hip/raft_hip.cmake
@@ -165,10 +165,22 @@ target_compile_options(
 # RAFT_COMPILE_LIBRARY builds explicit-instantiation TUs. The stock 8 sources
 # are rmat generators (random) + lanczos solvers (sparse/spectral). They do NOT
 # pull cutlass/cuco. Mark them LANGUAGE HIP.
-# The lanczos solver TUs pull the full cuSOLVER wrapper surface (syevdx /
-# syevjInfo / gesvdr / getriBatched), several of which have hipSOLVER signature
-# deltas; deferred behind RAFT_COMPILE_LANCZOS (OFF) off the validated path.
-option(RAFT_COMPILE_LANCZOS "Build the lanczos solver instantiations into libraft" OFF)
+#
+# The lanczos eigensolver's tridiagonal eigensolve (sterf/steqr) and the small
+# dense Householder GEMM run on the HOST via raft's Lapack<T> helpers, which on
+# CUDA wrap the cuSOLVER *Host CPU routines (cusolverDnS{gemm,sterf,steqr}Host).
+# Those *Host helpers have no hipSOLVER alias, so on HIP the helpers route to
+# host LAPACK/BLAS Fortran symbols directly (see spectral/detail/lapack.hpp).
+# That is the only blocker; with it the lanczos TUs build, so they default ON.
+option(RAFT_COMPILE_LANCZOS "Build the lanczos solver instantiations into libraft" ON)
+
+# Host LAPACK/BLAS (OpenBLAS + reference LAPACK) backs the lanczos Lapack<T>
+# helpers on HIP; the symbols (sterf/steqr/geqrf/ormqr/gemm) are dense host-side
+# ops on the small tridiagonal/projected matrices.
+if(RAFT_COMPILE_LANCZOS)
+  find_package(LAPACK REQUIRED)
+endif()
+
 if(RAFT_COMPILE_LIBRARY)
   set(RAFT_LIB_SOURCES
       ${RAFT_CPP_DIR}/src/raft_runtime/random/rmat_rectangular_generator_int64_double.cu
@@ -196,6 +208,9 @@ if(RAFT_COMPILE_LIBRARY)
                POSITION_INDEPENDENT_CODE ON
                HIP_ARCHITECTURES "${CMAKE_HIP_ARCHITECTURES}")
   target_link_libraries(raft_lib PUBLIC raft::raft)
+  if(RAFT_COMPILE_LANCZOS)
+    target_link_libraries(raft_lib PUBLIC LAPACK::LAPACK)
+  endif()
   target_compile_definitions(raft_lib PUBLIC RAFT_COMPILED)
 
   # raft::compiled is what tests link for the LIB variant.
