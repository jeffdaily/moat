{"kind":"phase","ts":"2026-06-05T06:33:10Z","phase":"test","seconds":0.038,"exit":0,"cmd":"python3 -c \nimport sys\n\n# Read CPU and GPU results\ncpu_hits = {}\nwith open('cpu.m8', 'r') as f:\n    for line in f:\n        fields = line.strip().split('\\t')\n        if len(fields) >= 12:\n            query, target = fields[0], fields[1]\n            key = (query, target)\n            cpu_hits[key] = line.strip()\n\ngpu_hits = {}\nwith open('gpu.m8', 'r') as f:\n    for line in f:\n        fields = line.strip().split('\\t')\n        if len(fields) >= 12:\n            query, target = fields[0], fields[1]\n            key = (query, target)\n            gpu_hits[key] = line.strip()\n\n# Check CPU hits in GPU\nmissing = []\ndifferent = []\nfor key, cpu_line in cpu_hits.items():\n    if key not in gpu_hits:\n        missing.append(key)\n    elif cpu_line != gpu_hits[key]:\n        different.append((key, cpu_line, gpu_hits[key]))\n\n# Report\nprint(f'CPU hits: {len(cpu_hits)}')\nprint(f'GPU hits: {len(gpu_hits)}')\nprint(f'Missing in GPU: {len(missing)}')\nprint(f'Different scores: {len(different)}')\n\nif missing:\n    print('\\nMissing hits:')\n    for key in missing[:5]:\n        print(f'  {key}')\n    if len(missing) > 5:\n        print(f'  ... and {len(missing)-5} more')\n\nif different:\n    print('\\nDifferent scores (first 3):')\n    for key, cpu, gpu in different[:3]:\n        print(f'  {key}')\n        print(f'    CPU: {cpu}')\n        print(f'    GPU: {gpu}')\n\nif len(missing) == 0 and len(different) == 0:\n    print('\\n✓ All CPU hits present in GPU with identical scores')\n    sys.exit(0)\nelse:\n    print('\\n✗ Validation failed')\n    sys.exit(1)\n"}
